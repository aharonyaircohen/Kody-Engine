{
  "name": "@kody-ade/kody-engine",
  "version": "0.1.1",
  "description": "Kody CI/CD pipeline engine — multi-agent pipeline for GitHub repos",
  "license": "MIT",
  "type": "module",
  "bin": {
    "kody-engine": "./dist/bin/cli.mjs"
  },
  "files": [
    "dist",
    "templates",
    "opencode"
  ],
  "scripts": {
    "copy:opencode": "rm -rf opencode && mkdir -p opencode && cp -r ../../.opencode/agents ../../.opencode/docs opencode/",
    "build": "tsup",
    "prepublishOnly": "pnpm build && pnpm copy:opencode"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.52",
    "@ai-sdk/mcp": "^1.0.30",
    "@anthropic-ai/sdk": "^0.80.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@octokit/core": "^7.0.6",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^22.0.1",
    "ai": "^6.0.97",
    "commander": "^14.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "17.2.3",
    "ms": "^2.1.3",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "slugify": "^1.6.6",
    "znv": "^0.5.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/ms": "^2.1.0",
    "@types/node": "^22.5.4",
    "tsup": "^8.5.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22"
  }
}
