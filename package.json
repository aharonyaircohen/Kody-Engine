{
  "name": "kody-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Kody Engine — Multi-agent CI/CD pipeline engine",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:canary": "echo 'canary passed'",
    "kody": "tsx src/engine/entry.ts",
    "kody:spec": "tsx src/engine/entry.ts --mode spec",
    "kody:impl": "tsx src/engine/entry.ts --mode impl",
    "kody:full": "tsx src/engine/entry.ts --mode full",
    "kody:rerun": "tsx src/engine/entry.ts --mode rerun",
    "kody:status": "tsx src/engine/entry.ts --mode status",
    "build:engine": "pnpm --filter @aguyinvest/kody-engine build",
    "publish:engine": "pnpm --filter @aguyinvest/kody-engine publish --access public"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.52",
    "@ai-sdk/mcp": "^1.0.30",
    "@anthropic-ai/sdk": "^0.80.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@octokit/core": "^7.0.6",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^22.0.1",
    "ai": "^6.0.97",
    "commander": "^14.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "17.2.3",
    "ms": "^2.1.3",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "slugify": "^1.6.6",
    "znv": "^0.5.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.39.4",
    "@types/ms": "^2.1.0",
    "@types/node": "^22.5.4",
    "eslint": "^9.16.0",
    "opencode-ai": "0.0.0-dev-202603021929",
    "prettier": "^3.4.2",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "4.0.16"
  }
}
